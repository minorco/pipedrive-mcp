{
  "name": "@comma-compliance/pipedrive-mcp",
  "version": "1.1.0",
  "description": "A Pipedrive CRM MCP server with full CRUD, custom field resolution, pagination, and safety guards",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
