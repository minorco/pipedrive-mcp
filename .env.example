# Required - company domain
PIPEDRIVE_COMPANY_DOMAIN=yourcompany         # e.g. "yourcompany" for yourcompany.pipedrive.com

# Required - authentication (set exactly one of the following)
PIPEDRIVE_API_TOKEN=your-api-token-here      # Personal API token, sent as ?api_token query param (does not expire)
# PIPEDRIVE_OAUTH_TOKEN=your-oauth-token     # OAuth access token, sent as Authorization: Bearer header
                                             # Note: access tokens expire (~1h). Token refresh is NOT handled by this
                                             # server, the hosting app must refresh and re-inject a valid token.

# Optional - Transport
PIPEDRIVE_TRANSPORT=stdio                   # stdio (default) or sse
PIPEDRIVE_SSE_HOST=0.0.0.0                  # SSE bind host
PIPEDRIVE_SSE_PORT=3100                     # SSE bind port

# Optional - HTTP
PIPEDRIVE_REQUEST_TIMEOUT_MS=30000          # HTTP request timeout

# Optional - Pagination
PIPEDRIVE_DEFAULT_LIMIT=25                  # Default page size
PIPEDRIVE_MAX_LIMIT=100                     # Max page size

# Optional - Rate Limiting
PIPEDRIVE_RATE_LIMIT_GENERAL_PER_2S=8       # General rate limit per 2s
PIPEDRIVE_RATE_LIMIT_SEARCH_PER_2S=4        # Search rate limit per 2s

# Optional - Caching
PIPEDRIVE_FIELD_CACHE_TTL_MS=300000         # Field metadata cache TTL (5 min)

# Optional - Feature Flags
PIPEDRIVE_ENABLE_WRITE_TOOLS=true           # Set false to disable all write tools

# Optional - Logging
LOG_LEVEL=info                              # debug, info, warn, error

# Optional - Sentry Error Tracking
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production             # Sentry environment tag
# SENTRY_RELEASE=                           # Sentry release tag
